<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NestVault.Client.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:f="clr-namespace:Fonts"
    xmlns:pageModels="clr-namespace:NestVault.Client.PageModels"
    xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    x:DataType="pageModels:LoginPageModel"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled"
    Title="Sign In">

    <Grid>
        <ScrollView>
            <VerticalStackLayout
                MaximumWidthRequest="420"
                VerticalOptions="Center"
                Padding="{StaticResource LayoutPadding}"
                Spacing="{StaticResource LayoutSpacing}">

                <Label
                    Text="{x:Static f:FluentUI.shield_lock_48_regular}"
                    FontFamily="{x:Static f:FluentUI.FontFamily}"
                    FontSize="64"
                    TextColor="{StaticResource Primary}"
                    HorizontalOptions="Center" />

                <Label
                    Text="NestVault"
                    Style="{StaticResource LargeTitle}"
                    HorizontalOptions="Center" />

                <Label
                    Text="Sign in to unlock your vault"
                    Style="{StaticResource Body2}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,20" />

                <sf:SfTextInputLayout Hint="Email">
                    <Entry
                        Text="{Binding Email}"
                        Keyboard="Email"
                        ReturnType="Next" />
                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Password" EnablePasswordVisibilityToggle="True">
                    <Entry
                        Text="{Binding Password}"
                        IsPassword="True"
                        ReturnType="Go"
                        ReturnCommand="{Binding LoginCommand}" />
                </sf:SfTextInputLayout>

                <Label
                    Text="{Binding ErrorMessage}"
                    IsVisible="{Binding HasError}"
                    TextColor="{StaticResource Red}"
                    Style="{StaticResource Body2}" />

                <Button
                    Text="Sign In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    HeightRequest="48" />

                <Button
                    Text="Create an account"
                    Command="{Binding GoToRegisterCommand}"
                    Style="{StaticResource SecondaryButton}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            HorizontalOptions="Center" />
    </Grid>
</ContentPage>
