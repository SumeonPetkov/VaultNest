{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=7667;Database=DB;User Id=Username;Password=Pass;"
  },

  "RateLimitOptions": {
    "EnableIpRateLimiting": true,
    "EnableUserIdRateLimiting": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "TimeoutInMinutes": 1
  },

  "JwtOptions": {
    "Issuer": "NestVault",
    "Audience": "NestVault.Client",
    "ExpireMinutes": 10,
    "RefreshTokenExpireDays": 30
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
